{
  "name": "@karim4987498/shared",
  "version": "1.0.0",
  "description": "Shared utilities and canonical type definitions for all REZ services and apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    // NOTE: If you add imports in consumer packages (e.g. @rez/shared/types/api),
    // you MUST add the matching export entry here, or Metro bundler will fail.
    "./types/api": {
      "import": "./dist/types/api.js",
      "require": "./dist/types/api.js",
      "types": "./dist/types/api.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./queue": {
      "import": "./dist/queue/index.js",
      "require": "./dist/queue/index.js",
      "types": "./dist/queue/index.d.ts"
    },
    "./webhook": {
      "import": "./dist/webhook/index.js",
      "require": "./dist/webhook/index.js",
      "types": "./dist/webhook/index.d.ts"
    }
  },
  "scripts": {
    "build": "node scripts/run-tsc.js",
    "test": "node --test test",
    "test:watch": "node --test --watch test"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bullmq": "^5.4.0",
    "crypto-js": "^4.2.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^2.3.0",
    "mongoose": "^8.17.2",
    "rate-limit-redis": "^4.1.5",
    "uuid": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.400.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  }
}
